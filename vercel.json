{
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/inbox-sweep",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/daily-review",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/run-tasks",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/oauth-gc",
      "schedule": "17 3 * * *"
    },
    {
      "path": "/api/cron/doctrine-sync",
      "schedule": "23 * * * *"
    }
  ]
}
