# QIG synapse daemon config. Deploy to ~/.config/qig/synapse.env (chmod 600).
# The daemon sources this file. Contains a bearer token once provisioned — never
# commit a filled-in copy.

QIG_MEMORY_URL=https://quauntum.dev

# REQUIRED. A scoped qig-memory key (memory:read + memory:write for the heartbeat).
# `setup.sh` provisions this automatically via POST /api/keys/synapse; or paste one
# after the = with no quotes. Empty => the daemon exits 78 (config guard) and will
# not spin-restart.
QIG_API_KEY=

# Poll cadence in seconds.
QIG_POLL_SECONDS=45

# Envelope TYPES that trigger a desktop ping (space-separated, case-insensitive).
QIG_URGENT_TYPES="DIRECTIVE BLOCKER HANDOFF RULING-REQUEST"

# OPTIONAL allow-list of recipient handles (space-separated, case-insensitive).
# Empty = surface EVERY urgent lane's mail (each ping names the receiving lane +
# its liveness). Set it to narrow which lanes ping this desktop.
QIG_WATCH=""

# A lane whose presence record (qig_presence_<handle>) has not refreshed within
# this many minutes is shown as DARK in the alert.
QIG_PRESENCE_STALE_MIN=20

# 1 = enrich each ping with a one-line model brief; 0 = subject only.
QIG_SUMMARIZE=1
# Summariser backend: ollama (LOCAL, free, private — default), claude (CLI), none.
# The daemon sends think:false and a verbatim-echo prompt (protocol v1.4: the
# synapse ECHOES, it does not compose). A fast/small local model is ideal.
QIG_SUMMARIZE_BACKEND=ollama
QIG_OLLAMA_URL=http://localhost:11434
QIG_OLLAMA_MODEL=liquidai/lfm2.5-1.2b-instruct:latest
# keep_alive=0 unloads the model from RAM/VRAM immediately after each summary
# (near-zero idle footprint). A warm value (e.g. 5m) trades RAM for speed.
QIG_OLLAMA_KEEPALIVE=0
